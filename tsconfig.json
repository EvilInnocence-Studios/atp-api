{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "es6",
    "module": "commonjs",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "jsx": "react",
    "paths": {
      "@common": [
        "src/common"
      ],
      "@common/*": [
        "src/common/*"
      ],
      "@common-shared": [
        "src/common-shared"
      ],
      "@common-shared/*": [
        "src/common-shared/*"
      ],
      "@core": [
        "src/core"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@core-shared": [
        "src/core-shared"
      ],
      "@core-shared/*": [
        "src/core-shared/*"
      ],
      "@store": [
        "src/store"
      ],
      "@store/*": [
        "src/store/*"
      ],
      "@store-shared": [
        "src/store-shared"
      ],
      "@store-shared/*": [
        "src/store-shared/*"
      ],
      "@subscription": [
        "src/subscription/index.ts"
      ],
      "@subscription/*": [
        "src/subscription/*"
      ],
      "@subscription-shared": [
        "src/subscription-shared/index.ts"
      ],
      "@subscription-shared/*": [
        "src/subscription-shared/*"
      ],
      "@uac": [
        "src/uac"
      ],
      "@uac/*": [
        "src/uac/*"
      ],
      "@uac-shared": [
        "src/uac-shared"
      ],
      "@uac-shared/*": [
        "src/uac-shared/*"
      ],
      "@analytics": [
        "src/analytics"
      ],
      "@analytics/*": [
        "src/analytics/*"
      ],
      "@analytics-shared": [
        "src/analytics-shared"
      ],
      "@analytics-shared/*": [
        "src/analytics-shared/*"
      ],
      "@brokered-products-plugin": [
        "src/brokered-products-plugin"
      ],
      "@brokered-products-plugin/*": [
        "src/brokered-products-plugin/*"
      ],
      "@brokered-products-plugin-shared": [
        "src/brokered-products-plugin-shared"
      ],
      "@brokered-products-plugin-shared/*": [
        "src/brokered-products-plugin-shared/*"
      ],
      "@comic": [
        "src/comic"
      ],
      "@comic/*": [
        "src/comic/*"
      ],
      "@comic-shared": [
        "src/comic-shared"
      ],
      "@comic-shared/*": [
        "src/comic-shared/*"
      ],
      "@donation-products-plugin": [
        "src/donation-products-plugin"
      ],
      "@donation-products-plugin/*": [
        "src/donation-products-plugin/*"
      ],
      "@donation-products-plugin-shared": [
        "src/donation-products-plugin-shared"
      ],
      "@donation-products-plugin-shared/*": [
        "src/donation-products-plugin-shared/*"
      ],
      "@gallery": [
        "src/gallery"
      ],
      "@gallery/*": [
        "src/gallery/*"
      ],
      "@gallery-shared": [
        "src/gallery-shared"
      ],
      "@gallery-shared/*": [
        "src/gallery-shared/*"
      ],
      "@theming": [
        "src/theming"
      ],
      "@theming/*": [
        "src/theming/*"
      ],
      "@theming-shared": [
        "src/theming-shared"
      ],
      "@theming-shared/*": [
        "src/theming-shared/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "./index.ts"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "_data/**",
    "deploy/**",
    "./deploy.ts"
  ],
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}